# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- AI proxy ---
# Production must use a backend/proxy endpoint so provider API keys are not exposed.
VITE_AI_PROXY_URL=
# Legacy name still supported for existing deployments.
VITE_GEMINI_PROXY_URL=

# --- Stock quote proxy ---
# Vercel can use the default /api/stock-quotes route.
# GitHub Pages/static hosting needs an external server-side proxy, such as
# workers/stock-quotes-worker.js deployed to Cloudflare Workers.
VITE_STOCK_QUOTE_PROXY_URL=

# --- FRED (St. Louis Fed) ---
# 申請：https://fred.stlouisfed.org/docs/api/api_key.html
VITE_FRED_API_KEY=

